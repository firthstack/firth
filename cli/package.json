{
  "name": "firth",
  "version": "0.0.8",
  "description": "The Firth CLI — provision and govern a project's cloud resources (Neon Postgres, Tigris storage, Fly.io compute) behind one credential seam.",
  "type": "module",
  "bin": {
    "firth": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "firth",
    "cli",
    "ai-agent",
    "neon",
    "tigris",
    "fly",
    "deploy",
    "secrets",
    "branching"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firthstack/firth.git",
    "directory": "cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').cpSync('../skills','dist/skills',{recursive:true})\"",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@insforge/sdk": "^1.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

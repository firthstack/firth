{
  "name": "firth-control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "firth": "dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').cpSync('src/cli/skills','dist/src/cli/skills',{recursive:true})\"",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "live:neon": "tsx scripts/live-neon-check.ts",
    "live:fly": "tsx scripts/live-fly-check.ts",
    "live:tigris": "tsx scripts/live-tigris-check.ts",
    "live:deploy": "tsx scripts/live-deploy-check.ts"
  },
  "dependencies": {
    "@insforge/sdk": "latest",
    "aws4fetch": "^1.0.20",
    "fastify": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

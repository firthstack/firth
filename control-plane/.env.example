# KEK version labels MUST be uppercase ([A-Z0-9_]): InsForge compute rejects
# env keys that aren't all-caps, so the key FIRTH_KEK_<VERSION> must be too.
FIRTH_KEK_CURRENT=V1
FIRTH_KEK_V1=<base64-32-bytes>
INSFORGE_BASE_URL=https://u4vrn3sx.us-east.insforge.app
INSFORGE_ANON_KEY=<anon-key>
INSFORGE_ADMIN_KEY=<ik_-admin-key>
# Optional: Firth's own Neon Platform API key (account-of-record provisioning).
# Without it, project create still works but provisions no Neon resource.
NEON_API_KEY=<neon_-platform-api-key>
PORT=8080
# Optional; gates live provisioning of that resource.
FLY_API_TOKEN=<fly-v1-api-token>
FLY_ORG_SLUG=<your-org-slug>
# Optional; gates live provisioning of that resource.
TIGRIS_ACCESS_KEY_ID=<tigris-access-key-id>
TIGRIS_SECRET_ACCESS_KEY=<tigris-secret-access-key>
